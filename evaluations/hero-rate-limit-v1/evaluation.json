{
  "version": 1,
  "id": "hero-rate-limit-v1",
  "task": "Add rate limiting to the public search API",
  "tieTolerance": { "absoluteScorePoints": 1 },
  "correctnessChecks": [
    {
      "id": "existing-tests",
      "type": "command",
      "command": "npm test",
      "timeoutSeconds": 300,
      "successExitCodes": [0],
      "weight": 20,
      "mandatory": true
    },
    {
      "id": "hidden-window-reset-test",
      "type": "command",
      "command": "node --experimental-strip-types --test hidden-tests/rate-limit-reset.test.ts",
      "timeoutSeconds": 300,
      "successExitCodes": [0],
      "weight": 20,
      "mandatory": true
    }
  ],
  "requirements": [
    {
      "id": "REQ-429",
      "description": "Requests above the configured limit return HTTP 429.",
      "weight": 3,
      "mandatory": true,
      "checks": [
        { "id": "REQ-429-test", "type": "command", "command": "npm test", "timeoutSeconds": 300, "successExitCodes": [0] }
      ]
    },
    {
      "id": "REQ-WINDOW-RESET",
      "description": "A new request window accepts traffic after reset.",
      "weight": 2,
      "mandatory": true,
      "checks": [
        { "id": "REQ-WINDOW-RESET-test", "type": "command", "command": "node --experimental-strip-types --test hidden-tests/rate-limit-reset.test.ts", "timeoutSeconds": 300, "successExitCodes": [0] }
      ]
    },
    {
      "id": "REQ-MIDDLEWARE",
      "description": "The public search endpoint uses the existing middleware architecture.",
      "weight": 2,
      "mandatory": true,
      "checks": [
        { "id": "REQ-MIDDLEWARE-import", "type": "text-present", "path": "src/public-search.ts", "text": "from \"./middleware.ts\"" }
      ]
    }
  ],
  "rules": [
    {
      "id": "RULE-AUTH-UNCHANGED",
      "description": "Authentication behavior remains unchanged.",
      "weight": 2,
      "severity": "material",
      "checks": [
        { "id": "RULE-AUTH-path", "type": "path-unchanged", "path": "src/auth.ts" }
      ]
    },
    {
      "id": "RULE-BILLING-UNCHANGED",
      "description": "Billing behavior remains unchanged.",
      "weight": 2,
      "severity": "material",
      "checks": [
        { "id": "RULE-BILLING-path", "type": "path-unchanged", "path": "src/billing.ts" }
      ]
    },
    {
      "id": "RULE-NO-NEW-RATE-LIMIT-PACKAGE",
      "description": "No new rate-limiting dependency is introduced.",
      "weight": 1,
      "severity": "normal",
      "checks": [
        { "id": "RULE-NO-NEW-RATE-LIMIT-PACKAGE-check", "type": "dependency-absent", "package": "express-rate-limit" }
      ]
    },
    {
      "id": "RULE-NO-PAGES-API",
      "description": "The stale pages/api architecture is not introduced.",
      "weight": 1,
      "severity": "normal",
      "checks": [
        { "id": "RULE-NO-PAGES-API-check", "type": "path-unchanged", "path": "pages/api/**" }
      ]
    }
  ],
  "changePolicy": {
    "allowedPaths": ["src/middleware.ts", "src/public-search.ts", "src/rate-limit.ts", "tests/**"],
    "protectedPaths": ["src/auth.ts", "src/billing.ts"],
    "ignoredPaths": ["dist/**", "coverage/**", ".camarade/**", "hidden-tests/**"],
    "requiredChangedPaths": ["src/middleware.ts"]
  },
  "dependencyPolicy": {
    "packageManager": "npm",
    "allowedAddedPackages": [],
    "forbiddenPackages": ["express-rate-limit"],
    "allowUnlistedAdditions": false
  },
  "telemetryPolicy": { "requireTokens": true, "requireRuntime": true },
  "hiddenAssets": ["hidden-tests/rate-limit-reset.test.ts"]
}
